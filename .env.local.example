# Supabase（dev プロジェクト）の接続情報。実値は .env.local に置く（コミットしない）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# サーバ専用（RLS バイパス）。NEXT_PUBLIC_ を付けないこと。
SUPABASE_SECRET_KEY=
# verify:nox-grants 用の Postgres 直結（Dashboard > Connect・session pooler）
SUPABASE_DB_URL=
# seed:f0 のテストユーザー共通パスワード（dev 専用・任意文字列）
SEED_PASSWORD=
